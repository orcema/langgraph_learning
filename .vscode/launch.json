{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug LangGraph agent",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/agent.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": true
    },
    {
      "name": "Attach to langgraph dev (Studio + breakpoints)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "justMyCode": false
    }
  ]
}
